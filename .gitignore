# 운영 로그 (에이전트 폴링 루프, 대시보드 서버, 자동 커밋)
workspaces/*/loop.log
dashboard/dashboard.log
scripts/auto-commit.log
.claude/settings.local.json
.env
.env.backup
config/*-token.txt
config/*-token*.txt
config/atlassian-org-id.txt

# 세션 JSONL — 대용량, 일일 아카이브 스크립트로 별도 커밋
sessions/**/*.jsonl

# 대용량 바이너리 (매뉴얼 이미지, PDF, CS첨부, 파싱 결과)
data/
reports/
dashboard/uploads/
dashboard/__pycache__/
