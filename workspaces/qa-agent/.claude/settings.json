{
  "enabledPlugins": {
    "telegram@claude-plugins-official": false,
    "playwright@claude-plugins-official": false,
    "superpowers@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": false,
    "supabase@claude-plugins-official": false,
    "atlassian@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": false,
    "context7@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "github@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": false
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash C:/MES/wta-agents/scripts/block-process-control.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "C:/Users/Administrator/AppData/Local/Programs/Python/Python311/python.exe C:/MES/wta-agents/scripts/tool-log-hook.py qa-agent"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "C:/Users/Administrator/AppData/Local/Programs/Python/Python311/python.exe C:/MES/wta-agents/scripts/notify-max-edit.py qa-agent"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(C:\\MES\\**)",
      "Edit(C:\\MES\\**)",
      "Write(C:\\MES\\**)",
      "Read(C:\\wMES\\**)",
      "Edit(C:\\wMES\\**)",
      "Write(C:\\wMES\\**)",
      "Read(C:\\Users\\Administrator\\.claude\\**)",
      "Edit(C:\\Users\\Administrator\\.claude\\**)",
      "Write(C:\\Users\\Administrator\\.claude\\**)",
      "Read(C:\\Users\\Administrator\\.ssh\\**)",
      "Read(D:\\csagent\\**)",
      "Edit(D:\\csagent\\**)",
      "Write(D:\\csagent\\**)",
      "Read(D:\\wMES_FILES\\**)",
      "Edit(D:\\wMES_FILES\\**)",
      "Write(D:\\wMES_FILES\\**)",
      "Read(\\\\192.168.1.6\\**)",
      "Read(\\\\192.168.0.210\\**)",
      "Bash(*)"
    ],
    "defaultMode": "dontAsk"
  }
}